# Required for AI analysis
# Gemini API key from Google AI Studio or Google Cloud.
GEMINI_API_KEY=

# Required for Reddit live data via Apify actor.
# The app will try these in order if a key is invalid, rate-limited, or out of credits.
APIFY_API_KEY_1=
APIFY_API_KEY_2=
APIFY_API_KEY_3=
APIFY_API_KEY_4=
# Also supported for existing local env files:
APPIFY_KEY_0=
APPIFY_KEY_1=

# Required for YouTube comments via YouTube Data API v3
YOUTUBE_API_KEY=

# Optional runtime settings
APP_ENV=local
DEFAULT_LOOKBACK_DAYS=90
MAX_ITEMS_PER_SOURCE=50
CANDIDATE_ITEMS_PER_SOURCE=100
CANDIDATE_OVERFETCH_MULTIPLIER=2
CANDIDATE_OVERFETCH_MAX=2000

# Optional if deployed behind a network that requires proxies
HTTP_PROXY=
HTTPS_PROXY=
